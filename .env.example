# ═══════════════════════════════════════════════════════════════
# BTC DUAL BOT — BINGX v2  |  .env.example
# Copia este archivo a .env y rellena tus valores reales.
# NUNCA subas el .env al repositorio.
# ═══════════════════════════════════════════════════════════════

# ── Exchange BingX ───────────────────────────────────────────
BINGX_API_KEY=
BINGX_API_SECRET=
# ⚠ Permisos necesarios: Read + Trade (NO Withdrawal — todo queda en BingX)
# Testnet en: https://testnet-api.bingx.com (DRY_RUN=true simula localmente)

# ── AI — Oracle principal (Claude) ───────────────────────────
ANTHROPIC_API_KEY=
# Obtener en: https://console.anthropic.com

# ── AI — Segunda opinión y noticias macro (Gemini) ───────────
GEMINI_API_KEY=
# Obtener en: https://aistudio.google.com/app/apikey (tier gratuito disponible)

# ── AI — Sentimiento X/Grok (Fase 2) ─────────────────────────
XAI_API_KEY=
# Obtener en: https://console.x.ai
X_API_KEY=
X_API_SECRET=
# Obtener en: https://developer.x.com

# ── Whale Alert API ───────────────────────────────────────────
WHALE_ALERT_API_KEY=
# Obtener en: https://whale-alert.io/api (tier gratuito: 10 req/min)
WHALE_ALERT_MIN_VALUE=5000000
# Mínimo en USD para considerar una transacción whale (default: $5M)

# ── Distribución de profit ────────────────────────────────────
PROFIT_THRESHOLD_USDT=100
# Distribuir cuando el profit acumulado >= $100 USDT
PROFIT_REINJECT_PCT=0.30
# 30% queda en Futures (no se mueve)
PROFIT_SPOT_PCT=0.40
# 40% compra BTC Spot (acumulación long-term)
PROFIT_EARN_PCT=0.30
# 30% va a BingX Flexible Earn (genera APY)
EARN_MIN_APY=2.0
# APY mínimo (%) para depositar en Earn. Si es menor → redirigir a Spot.

# ── Gestión de riesgo Futures ─────────────────────────────────
FUTURES_RISK_PCT=0.02
# 2% del balance por trade (MÁXIMO — el strategy manager no puede subir esto)
FUTURES_MAX_LEVERAGE=3
# Apalancamiento máximo: 3x (INAMOVIBLE)
FUTURES_ATR_MULTIPLIER=1.5
# Stop Loss = ATR × 1.5
FUTURES_RR_RATIO=2.0
# Take Profit = distancia_SL × 2.0 (ratio riesgo:beneficio mínimo)

# ── Gestión de riesgo Spot ────────────────────────────────────
SPOT_DIP_BUDGET_PCT=0.10
# 10% del balance spot disponible por compra de dip
SPOT_MAX_DIP_BUYS=3
# Máximo de compras consecutivas sin recuperación de precio
SPOT_MIN_USDT_RESERVE=50
# Reserva mínima en USDT spot: NUNCA se usa para DCA

# ── Bot ───────────────────────────────────────────────────────
INTERVAL_MINUTES=5
# Intervalo entre ciclos en minutos
DRY_RUN=true
# SIEMPRE empezar en true. Cambia a false solo para live trading.
STRATEGY_EVAL_INTERVAL=50
# Re-evaluar y adaptar estrategia cada N ciclos

# ── SaaS — Configuración multi-usuario ───────────────────────
ADMIN_EMAIL=
# Email del propietario. Al registrarse con este email queda como admin (is_admin=1, sin límites).

ANTHROPIC_API_KEY=
# Key compartida del servidor para usuarios sin key propia (Sonnet, mín. 15 min/ciclo).
# Si está vacía, los usuarios DEBEN aportar la suya para iniciar el bot.

CLAUDE_MODEL=claude-sonnet-4-6
# Modelo Claude usado por todos los bots (default: Sonnet). Cambiar a claude-opus-4-5 si se quiere Opus.

ENCRYPTION_KEY=
# Clave AES-256 para cifrar API keys en la DB. Generar con: openssl rand -hex 32

SESSION_SECRET=
# Secreto para las sesiones Express. Generar con: openssl rand -hex 32

# ── SaaS — Google OAuth (opcional) ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Crear en: console.cloud.google.com → APIs y servicios → Credenciales → OAuth 2.0
# URI de redirección autorizada: https://TU_DOMINIO/auth/google/callback
